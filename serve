#!/bin/sh

# Generate .env from Render environment variables
# This is required because Render sets OS-level env vars, not a .env file.
# Without this, Laravel falls back to defaults (127.0.0.1:3306) and connection fails.
echo "Generating .env from environment variables..."

# Write Aiven CA certificate to a file if provided
CA_CERT_PATH="/app/aiven-ca.crt"
if [ -n "$CA_certificate" ]; then
  echo "Writing Aiven CA certificate to ${CA_CERT_PATH}..."
  printf '%s' "$CA_certificate" > "$CA_CERT_PATH"
  SSL_CA_PATH="$CA_CERT_PATH"
else
  SSL_CA_PATH="/etc/ssl/certs/ca-certificates.crt"
fi

cat > .env <<EOF
APP_NAME=${APP_NAME:-GoBitrage}
APP_ENV=${APP_ENV:-production}
APP_KEY=${APP_KEY:-}
APP_DEBUG=${APP_DEBUG:-false}
APP_URL=${APP_URL:-http://localhost}

DB_CONNECTION=${DB_CONNECTION:-mysql}
DB_HOST=${DB_HOST:-127.0.0.1}
DB_PORT=${DB_PORT:-3306}
DB_DATABASE=${DB_DATABASE:-defaultdb}
DB_USERNAME=${DB_USERNAME:-avnadmin}
DB_PASSWORD=${DB_PASSWORD:-}

MYSQL_ATTR_SSL_CA=${SSL_CA_PATH}

LOG_CHANNEL=${LOG_CHANNEL:-stack}
LOG_LEVEL=${LOG_LEVEL:-debug}

CACHE_DRIVER=${CACHE_DRIVER:-file}
QUEUE_CONNECTION=${QUEUE_CONNECTION:-sync}
SESSION_DRIVER=${SESSION_DRIVER:-file}
SESSION_LIFETIME=${SESSION_LIFETIME:-120}
EOF

echo ".env file generated with DB_HOST=${DB_HOST} DB_PORT=${DB_PORT} SSL_CA=${SSL_CA_PATH}"

# Generate APP_KEY if missing
if [ -z "$APP_KEY" ]; then
  echo "APP_KEY is missing. Generating one..."
  php artisan key:generate --force
fi

# Wait for the database to be ready
echo "Testing database connection..."
until php -r "
try {
    require __DIR__.'/vendor/autoload.php';
    \$app = require_once __DIR__.'/bootstrap/app.php';
    \$kernel = \$app->make(Illuminate\Contracts\Console\Kernel::class);
    \$kernel->bootstrap();
    Illuminate\Support\Facades\DB::connection()->getPdo();
    echo \"Database is ready!\n\";
} catch (Exception \$e) {
    echo \"DB Connection failed: \" . \$e->getMessage() . \"\n\";
    exit(1);
}"; do
  echo "Waiting for database..."
  sleep 5
done

# Run migrations
php artisan migrate --force

# Start the server
php artisan serve --host=0.0.0.0 --port=${PORT:-10000}
